{
  "id": "task-monitor",
  "name": "Task Monitor",
  "version": "12.1.0",
  "description": "监控子任务生命周期、自动重试、任务链追踪、进度报告、主任务监控、停滞检测、超时检测、exec进程监控、失败实时上报、系统健康保障",
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "monitoring": {
        "type": "object",
        "properties": {
          "subtaskTimeout": { "type": "number", "default": 1800000 },
          "mainTaskTimeout": { "type": "number", "default": 86400000 },
          "stalledThreshold": { "type": "number", "default": 1800000 }
        }
      },
      "retry": {
        "type": "object",
        "properties": {
          "maxRetries": { "type": "number", "default": 2 },
          "retryDelayMs": { "type": "number", "default": 60000 }
        }
      },
      "maintenance": {
        "type": "object",
        "properties": {
          "sessionRetentionDays": { "type": "number", "default": 30 },
          "configBackupIntervalHours": { "type": "number", "default": 1 },
          "healthCheckEnabled": { "type": "boolean", "default": true }
        }
      },
      "notification": {
        "type": "object",
        "properties": {
          "channel": { "type": "string", "description": "通知渠道，如 wecom、telegram" },
          "target": { "type": "string", "description": "通知目标，如 wecom:YangKe" },
          "throttle": { "type": "number", "default": 1000, "description": "消息节流间隔(ms)" },
          "maxMessageLength": { "type": "number", "default": 4096, "description": "消息最大长度" }
        },
        "required": ["channel", "target"]
      }
    }
  }
}
