{
  "name": "task-monitor",
  "version": "14.0.0",
  "description": "OpenClaw 监控插件：子任务监控、自动重试、任务链追踪、超时检测",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "dependencies": {
    "async-lock": "^1.4.1",
    "async-mutex": "^0.5.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
