{
  "$schema": "./config.schema.json",
  "version": "1.0.0",
  "monitoring": {
    "subtaskTimeout": 3600000,
    "taskChainTimeout": 5400000,
    "stalledPendingThreshold": 3600000,
    "stalledRunningThreshold": 1800000,
    "mainTaskTimeout": 7200000
  },
  "retry": {
    "maxRetries": 2,
    "checkInterval": 10000,
    "spawnTimeout": 300000,
    "backoffMultiplier": 2,
    "initialDelay": 60000
  },
  "progress": {
    "enabled": true,
    "reportInterval": 60000,
    "timeoutCheckInterval": 60000
  },
  "notification": {
    "channel": "telegram",
    "target": "8665573247",
    "enabled": true,
    "throttle": 3000,
    "maxMessageLength": 200,
    "quietHours": {
      "enabled": false,
      "start": "23:00",
      "end": "07:00"
    },
    "types": {
      "subtaskSpawned": true,
      "subtaskCompleted": true,
      "subtaskFailed": true,
      "subtaskTimeout": false,
      "mainTaskCompleted": false,
      "taskChainTimeout": false,
      "stalledTask": true,
      "progress": false,
      "retry": true,
      "mainCompleted": false
    }
  },
  "messageQueue": {
    "maxQueueSize": 100,
    "maxRetries": 3,
    "retryInterval": 5000
  },
  "storage": {
    "stateDir": "~/.openclaw/extensions/task-monitor/state",
    "tasksDir": "~/.openclaw/workspace/memory/tasks"
  },
  "logging": {
    "level": "info"
  }
}
